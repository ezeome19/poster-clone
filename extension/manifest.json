{
  "manifest_version": 3,
  "name": "PosterClone — Image Importer",
  "description": "Click any image on Pinterest or Cosmos.so to import it into PosterClone and turn it into a printed product.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.pinterest.com/*",
    "https://pinterest.com/*",
    "https://www.cosmos.so/*",
    "https://cosmos.so/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.pinterest.com/*",
        "https://pinterest.com/*",
        "https://www.cosmos.so/*",
        "https://cosmos.so/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
